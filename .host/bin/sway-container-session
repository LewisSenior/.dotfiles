#!/bin/bash
# greetd session command: launch the containerized Arch sway desktop.
# Runs as the authenticated user (rootless podman). If podman/sway fail,
# greetd drops back to the greeter; diagnostics go to the log below.
#
# Session model: full-system systemd is PID 1 (namespaced root via
# --userns=keep-id --user 0 + --systemd=always). It boots multi-user.target,
# which starts sway.service; that unit runs sway as the non-root user (uid
# 1000 = you, via keep-id) under dbus-run-session (its own session bus). On
# sway exit/logout the unit runs `systemctl poweroff`, so the container stops,
# this podman run returns, and greetd shows the greeter.
#
# We do NOT run an in-container logind user session (systemd 261's userdb
# can't resolve the keep-id user in this nested userns). Instead — the
# distrobox/toolbox pattern — the host PipeWire socket is forwarded in for
# audio, into a host-backed bind-mounted runtime dir (/run/user/UID) so
# clients find it. The session bus is the container's own (dbus-run-session);
# there is no host display to forward since sway itself is the compositor.
# The host system D-Bus is deliberately NOT forwarded (it would let the
# container power off / control the host).
#
# Seat handling: seatd runs on the HOST; its socket is bind-mounted in and
# sway uses LIBSEAT_BACKEND=seatd. DRM-master and input fds arrive over the
# socket (opened host-side), so the container only needs the render node
# (/dev/dri) plus /dev/input + /run/udev visible for libinput enumeration.
# container-device-groups.service maps the host device GIDs to the user.
#
# Realtime: sway keeps cap_sys_nice, so --cap-add=sys_nice is REQUIRED here or
# execve of sway EPERMs. --ulimit rtprio/nice supply the scheduling budget
# (the host grants it via the pipewire group + re-login; see pre-req.sh).
set -u

IMAGE="localhost/arch-sway"
RUNTIME_DIR="/run/user/$(id -u)"
CRUNTIME="$RUNTIME_DIR/sway-container"   # host-backed XDG_RUNTIME_DIR for the container
LOG="$HOME/.local/state/sway-container.log"

mkdir -p "$CRUNTIME" "$(dirname "$LOG")"
chmod 700 "$CRUNTIME"
echo "=== sway-container-session $(date -Is)" >>"$LOG"

# Forward the host PipeWire socket (audio) into the runtime dir if present.
# NOTE: deliberately do NOT forward the host system D-Bus socket. A full
# systemd container that can reach the host system bus can drive the host's
# logind (poweroff/reboot/suspend) as uid 1000, which polkit authorises — that
# once shut the host down. waybar's network/battery/backlight lose host data;
# that is an acceptable trade for not handing the container host control.
fwd=()
[[ -S "$RUNTIME_DIR/pipewire-0" ]] && fwd+=(-v "$RUNTIME_DIR/pipewire-0:$RUNTIME_DIR/pipewire-0")

# Realtime is best-effort. Only request the rtprio budget the host actually
# grants (via the pipewire group + re-login): crun REFUSES to start the whole
# container if --ulimit exceeds the caller's hard limit, so gate on it. sway
# runs fine without it (just no realtime scheduling).
rt=()
hr="$(ulimit -Hr 2>/dev/null || echo 0)"
[[ "$hr" == unlimited ]] && hr=95
if [[ "$hr" =~ ^[0-9]+$ && "$hr" -ge 1 ]]; then
    rt+=(--ulimit "rtprio=$hr")
    # (no --ulimit nice: RLIMIT_NICE uses a 20-n encoding, not the nice value,
    #  and it's redundant with rtprio RT scheduling. sway.service's LimitNICE
    #  applies negative nice when the container inherits the budget.)
else
    echo "note: no rtprio budget (add yourself to the pipewire group + re-login for realtime); starting without it" >>"$LOG"
fi

exec podman run --rm --replace --name sway-desktop \
  --systemd=always \
  --net=host --ipc=host \
  --userns=keep-id --user 0 \
  --group-add keep-groups \
  --security-opt label=disable \
  --cap-add=sys_nice \
  "${rt[@]}" \
  --device /dev/dri \
  -v /dev/input:/dev/input \
  -v /run/seatd.sock:/run/seatd.sock \
  -v /run/udev:/run/udev:ro \
  -v "$CRUNTIME:$RUNTIME_DIR" \
  "${fwd[@]}" \
  -v "$HOME:$HOME" \
  "$IMAGE" >>"$LOG" 2>&1

# ROOTFUL FALLBACK (pre-approved, use only if rootless fails at DRM/VT):
# replace the exec above with a sudo rule for
#   sudo podman run ... --user "$(id -u):$(id -g)" (same flags, drop
#   --userns=keep-id/--group-add) and add
#   'lewis ALL=(root) NOPASSWD: /usr/bin/podman run *' to sudoers.d.

# SSH config template — the real config is LOCAL-ONLY and gitignored.
#
# install.sh copies this file to ssh/.ssh/config on first run if it doesn't
# exist. Put real hostnames, IPs and usernames in that copy only; they must
# never be committed (this repo is public).

Host *
	IdentityAgent ~/.1password/agent.sock

# Template: legacy network kit that only speaks old algorithms.
# Scope the weakened crypto to the specific hosts that need it —
# never enable these under `Host *`.
Host legacy-router-example
	HostName <ip-or-hostname>
	Port <port>
	User <username>
	HostKeyAlgorithms +ssh-rsa
	KexAlgorithms +diffie-hellman-group1-sha1
	PubKeyAcceptedAlgorithms +ssh-rsa
	ControlMaster auto
	ControlPath /tmp/ssh_mux_%h_%p_%r
	ControlPersist yes

# Template: dev box
Host dev-example
	HostName <ip-or-hostname>
	User <username>
	StrictHostKeyChecking accept-new

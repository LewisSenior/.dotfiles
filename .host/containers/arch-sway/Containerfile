# Arch desktop image for the containerized sway session.
# Host (Debian) provides: greetd, seatd, podman, pipewire. This image is the
# actual desktop. Build with .host/containers/arch-sway/build.sh
FROM docker.io/library/archlinux:latest

ARG USERNAME=lewis
ARG UID=1000

# Core desktop + tooling (mirrors the old install.sh Arch branch, minus host-isms)
RUN pacman -Syu --noconfirm --needed \
    base-devel git sudo \
    mesa vulkan-intel \
    sway swaybg swaylock swayidle swaync \
    waybar wofi kanshi grim slurp wl-clipboard \
    xorg-xwayland \
    alacritty tmux zsh starship fzf tree rsync wget openssh man-pages \
    neovim stow github-cli go jq \
    firefox \
    pipewire wireplumber pavucontrol playerctl alsa-utils \
    ttf-hack-nerd noto-fonts \
    && pacman -Scc --noconfirm

# Locale
RUN sed -i 's/^#en_GB.UTF-8/en_GB.UTF-8/' /etc/locale.gen && locale-gen
ENV LANG=en_GB.UTF-8

# Unprivileged user matching the host user; rootless --userns=keep-id maps
# host uid 1000 onto this. $HOME is bind-mounted at runtime, so the image
# home only needs to exist with the right ownership.
RUN useradd -m -u ${UID} -s /bin/zsh ${USERNAME} \
    && echo "${USERNAME} ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/${USERNAME}

# AUR: yay, then packages not in the official repos.
# Tolerant on purpose — an AUR outage shouldn't brick the desktop image build;
# missing bits can be installed later from inside the container with yay.
USER ${USERNAME}
WORKDIR /home/${USERNAME}
RUN git clone https://aur.archlinux.org/yay-bin.git /tmp/yay-bin \
    && cd /tmp/yay-bin && makepkg -si --noconfirm && cd / && rm -rf /tmp/yay-bin
RUN yay -S --noconfirm autotiling || echo "WARN: autotiling failed, install later: yay -S autotiling"
RUN yay -S --noconfirm 1password || echo "WARN: 1password failed, install later: yay -S 1password"

# Realtime scheduling: KEEP cap_sys_nice on the sway binary. The session runs
# with --cap-add=sys_nice + --ulimit rtprio, so this effective file cap is
# honored and sway.service can use LimitRTPRIO. NOTE: because the cap is kept,
# the image MUST run with --cap-add=sys_nice or execve of sway EPERMs.
# gst-ptp-helper carries net caps that can't be granted in the userns and
# isn't on the desktop path — strip it so it never EPERMs on exec.
USER root
RUN setcap -r /usr/lib/gstreamer-1.0/gst-ptp-helper 2>/dev/null || true

# dbus-broker's launcher fails in this rootless container (ENOTCONN / "Package
# not installed"), which wedges logind and stalls boot. Swap to the reference
# dbus-daemon implementation, which works in containers.
RUN pacman -Rdd --noconfirm dbus-broker-units \
 && pacman -Sy --noconfirm dbus-daemon-units \
 && pacman -Scc --noconfirm

# --- systemd system container ---
# Run under `podman run --systemd=always --userns=keep-id --user 0` (see
# sway-container-session): systemd is PID 1 as namespaced root, sway.service
# drops to the non-root user via a PAM login session.
#
# Mask units that hang or are meaningless in a rootless container (no real
# hardware/modules/ttys; network + udev come from the host).
RUN for u in \
        systemd-firstboot.service systemd-remount-fs.service \
        systemd-modules-load.service systemd-hwdb-update.service \
        systemd-udevd.service systemd-udevd-control.socket \
        systemd-udevd-kernel.socket systemd-udev-trigger.service \
        systemd-networkd.service systemd-networkd.socket \
        systemd-networkd-wait-online.service \
        [email protected] [email protected] console-getty.service \
        systemd-ask-password-console.path systemd-ask-password-wall.path ; do \
        ln -sf /dev/null "/etc/systemd/system/$u" ; done

# Device-group fixup (host device GIDs -> matching groups for the user) and the
# sway session unit; boot straight to it via multi-user.target.
COPY container-device-groups.sh /usr/local/bin/container-device-groups
COPY container-device-groups.service /etc/systemd/system/container-device-groups.service
COPY sway.service /etc/systemd/system/sway.service
RUN chmod 755 /usr/local/bin/container-device-groups \
 && systemctl set-default multi-user.target \
 && mkdir -p /etc/systemd/system/multi-user.target.wants \
 && ln -sf /etc/systemd/system/sway.service \
        /etc/systemd/system/multi-user.target.wants/sway.service \
 && ln -sf /etc/systemd/system/container-device-groups.service \
        /etc/systemd/system/multi-user.target.wants/container-device-groups.service

# Optional sudo password (LAST step, so busting its cache is cheap). If
# build.sh passed a 'sudopw' build secret, set it as ${USERNAME}'s password and
# require it for sudo; otherwise passwordless sudo (from the useradd step)
# stays. The secret is never written to a layer or the (public) repo — only the
# /etc/shadow hash lands in the LOCAL image. Build secrets are NOT part of the
# layer cache key, so build.sh passes a fresh SUDOPW_EPOCH each run to force
# this step to re-run and reflect the current password (or its absence).
ARG SUDOPW_EPOCH=0
RUN --mount=type=secret,id=sudopw,required=false \
    : "cache-bust=${SUDOPW_EPOCH}"; \
    if [ -s /run/secrets/sudopw ]; then \
        printf '%s:%s\n' "${USERNAME}" "$(cat /run/secrets/sudopw)" | chpasswd \
        && echo "${USERNAME} ALL=(ALL) ALL" > /etc/sudoers.d/${USERNAME} \
        && echo "sudo: password required for ${USERNAME}"; \
    else \
        echo "${USERNAME} ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/${USERNAME} \
        && echo "sudo: passwordless (no sudopw secret given)"; \
    fi

CMD ["/sbin/init"]

[Unit]
Description=Sway session (container desktop payload)
After=systemd-user-sessions.service dbus.service container-device-groups.service
Wants=dbus.service
Requires=container-device-groups.service

[Service]
Type=simple
# Run the desktop as the non-root user (uid 1000 = you, via keep-id). We do
# NOT open a logind/pam_systemd session (systemd 261's userdb can't resolve
# the keep-id user in this nested userns), and we do NOT use User=lewis:
# systemd would reset the supplementary groups to lewis's *container* groups,
# discarding the host video/render/input/seat GIDs that `--group-add
# keep-groups` puts on PID 1. Those host GIDs are unmapped in the userns (they
# display as "nobody"/65534) and can't be granted any other way, so without
# them sway gets "Permission denied" on /run/seatd.sock. Instead this service
# runs as root (inheriting PID 1's keep-groups) and drops to uid 1000 with
# `setpriv --keep-groups`, which preserves those host GIDs.
# XDG_RUNTIME_DIR is a host-backed bind mount (see the session script);
# dbus-run-session provides the session bus (portals, swaync); the host
# PipeWire socket is forwarded in for audio.
WorkingDirectory=/home/lewis
Environment=XDG_RUNTIME_DIR=/run/user/1000
Environment=XDG_SESSION_TYPE=wayland
Environment=XDG_CURRENT_DESKTOP=sway
Environment=MOZ_ENABLE_WAYLAND=1
Environment=LIBSEAT_BACKEND=seatd
ExecStart=/usr/bin/setpriv --reuid 1000 --regid 1000 --keep-groups /usr/bin/dbus-run-session /usr/bin/sway
Restart=no
# Also send sway's output to the container console so it reaches the podman
# log (~/.local/state/sway-container.log); otherwise it only hits the internal
# journal, which is gone once the container exits.
StandardOutput=journal+console
StandardError=journal+console
# Realtime scheduling (host grants rtprio via the pipewire group; container
# gets it via --ulimit rtprio; sway keeps cap_sys_nice + --cap-add=sys_nice).
LimitRTPRIO=95
LimitNICE=-19
# When sway exits/logout or fails, stop the CONTAINER (never the host!) so
# `podman run` returns and greetd falls back to the greeter. Signal the
# container's PID 1 (systemd) with SIGRTMIN+3 (= start poweroff.target); the
# signal is confined to the container PID namespace so it cannot reach the
# host. '+' runs it as root, which is required to signal PID 1.
# DO NOT use `systemctl poweroff` here: with any host system bus reachable it
# powers off the HOST (uid 1000 is polkit-authorized there).
ExecStopPost=+/usr/bin/kill -s RTMIN+3 1

[Install]
WantedBy=multi-user.target
